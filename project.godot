[display]

window/size/viewport_width=630
window/size/viewport_height=500
window/size/window_width_override=1260
window/size/window_height_override=1000
window/stretch/mode="canvas_items"

[gui]

theme/custom_font="uid://b8df2sfql42g7"

[physics]

